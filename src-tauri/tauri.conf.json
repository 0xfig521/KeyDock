{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KeyDock",
  "version": "0.6.1",
  "identifier": "dev.keydock.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KeyDock",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; font-src 'self'",
      "capabilities": [
        {
          "identifier": "default",
          "description": "Default capability",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default",
            "clipboard-manager:default",
            "opener:default",
            "updater:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnRzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFOTIzNzI0MDM1OTA2NkQKUldSdEJsa0RKRGVTSGdrUWlYeHJIUFo5NkNWa2lSelpvT0w2TEkvZHN0UElnWW10ZlU0bTdYUlAK",
      "endpoints": [
        "https://github.com/0xfig-labs/KeyDock/releases/latest/download/update.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
